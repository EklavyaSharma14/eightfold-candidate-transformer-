{
  "_comment": "slim recruiter-facing config - subset/rename fields, national phone format, no provenance, errors if name is missing",
  "fields": [
    { "path": "id", "from": "candidate_id", "type": "string", "required": true },
    { "path": "full_name", "from": "full_name", "type": "string", "required": true },
    { "path": "primary_email", "from": "emails[0]", "type": "string" },
    { "path": "phone_display", "from": "phones[0]", "type": "string", "normalize": "national" },
    { "path": "current_title", "from": "headline", "type": "string" },
    { "path": "years_experience", "from": "years_experience", "type": "number", "required": true },
    { "path": "skill_names", "from": "skills[].name", "type": "string[]" },
    { "path": "country", "from": "location.country", "type": "string" }
  ],
  "include_confidence": true,
  "include_provenance": false,
  "on_missing": "error"
}
